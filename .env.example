# Optional. The deterministic local embedding provider is the default.
CONTEXTFORGE_LOG_LEVEL=INFO
CONTEXTFORGE_DB_DIR=.contextforge
CONTEXTFORGE_EMBEDDING_PROVIDER=local
CONTEXTFORGE_MAX_FILE_BYTES=2000000
CONTEXTFORGE_GRAPH_MAX_DEPTH=2
CONTEXTFORGE_GRAPH_MAX_NODES=40
CONTEXTFORGE_SEMANTIC_DIMENSIONS=384
